DEVICE_ID=device-001
TENANT_ID=tenant-a
DEVICE_MODEL=edge-sensor-v1
DEVICE_PROFILE=default

ISSUER_BASE_URL=https://issuer.local
GATEWAY_BASE_URL=https://gateway.local
BOOTSTRAP_TOKEN=replace-me

IDENTITY_STORAGE_DIR=./identity
DEVICE_IDENTITY_PASSPHRASE=replace-with-strong-device-secret
HTTP_TIMEOUT=10s
LOG_LEVEL=info

# Optional
# FORCE_BOOTSTRAP=false
# RENEW_BEFORE=72h
# GATEWAY_CA_FILE=./certs/root.cert.pem
# GATEWAY_SERVER_NAME=gateway.local
# PING_PATH=/api/v1/ping
# TELEMETRY_PATH=/api/v1/telemetry
# TELEMETRY_TEMPERATURE=21.5
# TELEMETRY_BATTERY_PCT=87
# FIRMWARE_VERSION=simulator-1.0.0
# TELEMETRY_STATUS=nominal
